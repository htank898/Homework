<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Atlas Freight Agent — can create/edit loads, view carriers, initiate AI calling, and confirm bookings. Cannot blacklist carriers (supervisor only).</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Atlas Agent</label>
    <userLicense>Salesforce</userLicense>

    <!-- Load__c -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Load__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Carrier__c -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Carrier__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Call_Log__c -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Call_Log__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Load_Carrier_Interest__c -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Load_Carrier_Interest__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Rate_Benchmark__c (read-only for agents) -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Rate_Benchmark__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Rate_Confirmation__c -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Rate_Confirmation__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Carrier_Flag_History__c (create only — cannot approve) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Carrier_Flag_History__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- App access -->
    <applicationVisibilities>
        <application>Atlas</application>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- Tab access -->
    <tabSettings>
        <tab>Atlas_Loads</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Atlas_Carriers</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Atlas_Rate_Board</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Atlas_Analytics</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Custom settings access -->
    <customSettingAccesses>
        <enabled>true</enabled>
        <name>BlandAI_Config__c</name>
    </customSettingAccesses>
</PermissionSet>
